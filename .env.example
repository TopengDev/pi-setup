# ─── Google AI Studio (image generation, Gemini) ─────────────────────────────
export GEMINI_API_KEY=""

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Classic PAT with repo scope
export GH_TOKEN=""

# ─── Infrastructure ──────────────────────────────────────────────────────────
# Cloudflare DNS
export CLOUDFLARE_API_TOKEN=""
export CLOUDFLARE_ZONE_ID=""

# VPS
export VPS_HOST=""
export VPS_USER=""
export VPS_PASSWORD=""
