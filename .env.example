# ──────────────────────────────────────────────────────────────────────────────
# pi environment — secrets template
#
# Copy to ~/.pi/agent/secrets.env and fill in real values.
# NEVER commit this file with real credentials.
# ──────────────────────────────────────────────────────────────────────────────

# ─── AI Provider Keys ────────────────────────────────────────────────────────
export DEEPSEEK_API_KEY=""
