#!/usr/bin/env bash
# pre-push secret scan (gitleaks). OPT-IN per repo via:
#   git config core.hooksPath config/git/hooks
# (or globally:  git config --global core.hooksPath ~/.pi/agent/config/git/hooks)
#
# Fires before `git push`. Scans the exact commits being pushed (per ref) for
# secrets and BLOCKS the push (exit 1) on a hit.
#
# Windows / Git Bash note: gitleaks ships native Windows binaries. This hook only
# needs `gitleaks` resolvable on PATH (Git Bash inherits the Windows PATH, so a
# `winget`/`scoop`/`choco`-installed gitleaks.exe is found automatically). If
# gitleaks is NOT installed, the hook FAILS OPEN (warns + allows) so a missing
# tool never bricks every push on the machine.
#
# git invokes pre-push with args:   <remote-name> <remote-url>
# and feeds ref updates on STDIN, one per line:
#   <local_ref> <local_oid> <remote_ref> <remote_oid>
# We scan the range <remote_oid>..<local_oid> for each updated ref so only the
# NEW commits are checked (fast; doesn't re-scan all of history every push).
#
# Edge cases handled:
#   * Branch deletion (local_oid all-zero) → nothing to scan, skip that ref.
#   * New branch / first push (remote_oid all-zero) → scan commits reachable
#     from local_oid but not from any existing remote ref (avoids re-flagging
#     history that's already public elsewhere; still catches genuinely-new work).
#   * gitleaks not installed → fail OPEN (allow push) but print a loud warning.
#
# BYPASS (false positives / intentional test fixtures):
#   git push --no-verify        # skips ALL pre-push hooks for that one push
# Prefer fixing the finding or adding a gitleaks:allow comment / .gitleaksignore.
#
# Config: config/git/hooks/gitleaks.toml (adds Anthropic sk-ant- rules on top of
# gitleaks' defaults — the default ruleset in 8.21.x lacks them).

set -uo pipefail

ZERO="0000000000000000000000000000000000000000"
HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
GL_CONFIG="$HOOK_DIR/gitleaks.toml"

# ── tool presence: fail OPEN but loud ────────────────────────────────────────
if ! command -v gitleaks >/dev/null 2>&1; then
  echo "[pre-push] WARNING: gitleaks not found on PATH — secret scan SKIPPED." >&2
  echo "[pre-push]          install it to re-enable protection:" >&2
  echo "[pre-push]            Windows:  winget install gitleaks   (or scoop/choco install gitleaks)" >&2
  echo "[pre-push]            Linux:    your package manager (e.g. paru -S gitleaks)" >&2
  exit 0
fi

CONFIG_ARG=()
[ -f "$GL_CONFIG" ] && CONFIG_ARG=(-c "$GL_CONFIG")

FOUND=0

# Read ref updates from stdin. If stdin is empty (rare/manual invocation), fall
# back to scanning HEAD against its upstream so a direct run still does something.
had_input=0
while read -r local_ref local_oid remote_ref remote_oid; do
  had_input=1
  [ -z "${local_ref:-}" ] && continue

  # Branch/tag deletion — local side is all-zero, nothing to scan.
  if [ "$local_oid" = "$ZERO" ]; then
    continue
  fi

  if [ "$remote_oid" = "$ZERO" ]; then
    # New ref on the remote: scan new commits not already on any remote.
    range_opts="$local_oid --not --remotes"
    label="new ref ${local_ref} (commits not yet on any remote)"
  else
    # Updating an existing ref: scan only the delta being pushed.
    range_opts="${remote_oid}..${local_oid}"
    label="${local_ref}  ${remote_oid:0:8}..${local_oid:0:8}"
  fi

  echo "[pre-push] scanning ${label} for secrets…" >&2
  if ! gitleaks git "${CONFIG_ARG[@]}" --no-banner --redact --log-opts="$range_opts" . ; then
    FOUND=1
  fi
done

# Manual/empty-stdin fallback: scan HEAD vs its upstream (if any).
if [ "$had_input" -eq 0 ]; then
  if upstream="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null)"; then
    echo "[pre-push] (no ref input) scanning ${upstream}..HEAD…" >&2
    gitleaks git "${CONFIG_ARG[@]}" --no-banner --redact --log-opts="${upstream}..HEAD" . || FOUND=1
  else
    echo "[pre-push] (no ref input, no upstream) scanning full working tree…" >&2
    gitleaks git "${CONFIG_ARG[@]}" --no-banner --redact . || FOUND=1
  fi
fi

if [ "$FOUND" -ne 0 ]; then
  echo "" >&2
  echo "════════════════════════════════════════════════════════════════════" >&2
  echo " PUSH BLOCKED: gitleaks found potential secret(s) in the pushed commits." >&2
  echo "" >&2
  echo "  • Review the findings above (values are redacted)." >&2
  echo "  • Remove the secret + rewrite the offending commit(s), then re-push." >&2
  echo "  • False positive? add a 'gitleaks:allow' comment on that line, or list" >&2
  echo "    it in a .gitleaksignore, OR bypass this one push with:" >&2
  echo "        git push --no-verify" >&2
  echo "════════════════════════════════════════════════════════════════════" >&2
  exit 1
fi

echo "[pre-push] no secrets detected — push allowed." >&2
exit 0
